# Database Connection
# Replace with your actual PostgreSQL connection string. 
# For example, if you use Supabase or a local Postgres instance:
# DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"
DATABASE_URL=""

# NextAuth Configuration
# You can generate a random secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-jwt-key"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Credentials
# You can get these by creating a project in the Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
